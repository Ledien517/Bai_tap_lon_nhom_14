<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="600.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.auction.client.controller.ItemManagementController">

    <!-- Thanh Header -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-background-color: #388e3c; -fx-padding: 15;">
            <Label text="QUẢN LÝ SẢN PHẨM (SELLER)" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Đăng xuất" onAction="#handleLogout" style="-fx-background-color: white; -fx-text-fill: #388e3c; -fx-font-weight: bold;"/>
        </HBox>
    </top>

    <!-- Phần thân chính -->
    <center>
        <VBox spacing="15" style="-fx-padding: 20;">
            <!-- Form nhập liệu: Chia làm 2 dòng cho thoáng -->
            <GridPane hgap="10" vgap="10" style="-fx-background-color: #f4f4f4; -fx-padding: 15; -fx-background-radius: 5;">
                <columnConstraints>
                    <ColumnConstraints minWidth="50" />
                    <ColumnConstraints minWidth="150" />
                    <ColumnConstraints minWidth="50" />
                    <ColumnConstraints minWidth="150" />
                    <ColumnConstraints minWidth="100" />
                    <ColumnConstraints minWidth="150" />
                </columnConstraints>

                <children>
                    <Label text="Loại:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <ComboBox fx:id="cbType" prefWidth="150" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                    <Label text="Mã ID:" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
                    <TextField fx:id="txtId" promptText="VD: SP001" GridPane.columnIndex="3" GridPane.rowIndex="0"/>

                    <Label text="Tên SP:" GridPane.columnIndex="4" GridPane.rowIndex="0"/>
                    <TextField fx:id="txtName" promptText="Tên sản phẩm" GridPane.columnIndex="5" GridPane.rowIndex="0"/>

                    <Label text="Giá khởi điểm:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <TextField fx:id="txtPrice" promptText="0.0" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                    <Label fx:id="lblExtraParam" text="Thông tin thêm:" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
                    <TextField fx:id="txtExtraParam" promptText="Nhập thêm..." GridPane.columnIndex="3" GridPane.rowIndex="1" GridPane.columnSpan="2"/>

                    <Button onAction="#handleAddItem" prefWidth="150" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-weight: bold;" text="THÊM SẢN PHẨM" GridPane.columnIndex="5" GridPane.rowIndex="1" />
                </children>
            </GridPane>

            <!-- Bảng hiển thị dữ liệu -->
            <TableView fx:id="table" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="idCol" prefWidth="80" text="Mã ID" />
                    <TableColumn fx:id="typeCol" prefWidth="100" text="Loại" />
                    <TableColumn fx:id="nameCol" prefWidth="250" text="Tên Sản Phẩm" />
                    <TableColumn fx:id="priceCol" prefWidth="120" text="Giá Hiện Tại" />
                    <!-- BỔ SUNG CỘT STATUS: Trong Controller của bạn có cột này -->
                    <TableColumn fx:id="statusCol" prefWidth="120" text="Trạng Thái" />
                </columns>
            </TableView>
        </VBox>
    </center>
</BorderPane>