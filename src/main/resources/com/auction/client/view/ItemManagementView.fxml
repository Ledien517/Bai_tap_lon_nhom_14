<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="700.0" prefWidth="1000.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.ItemManagementController" styleClass="root">
    <!-- Thanh Header -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" styleClass="header-bar">
            <Label text="SÀN ĐẤU GIÁ" styleClass="title-label"/>
            <Label text="|  Quản lý Người Bán" styleClass="subtitle-label"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="lblSellerInfo" text="Chào, Seller" styleClass="label" style="-fx-font-weight: bold;"/>
            <Label fx:id="lblBalance" text="Số dư: 0.00 $" styleClass="label" style="-fx-font-weight: bold; -fx-text-fill: #10b981;"/>
            <Button text="Rút tiền" onAction="#handleWithdraw" styleClass="button" style="-fx-background-color: #3b82f6;"/>
            <Button text="Đăng xuất" onAction="#handleLogout" styleClass="button-danger"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="20" style="-fx-padding: 20;">
            <!-- Form Đăng ký sản phẩm -->
            <VBox spacing="12" styleClass="card">
                <Label text="🏷 Đăng bán sản phẩm mới" styleClass="subtitle-label" style="-fx-font-weight: bold;"/>
                <GridPane hgap="15" vgap="12">
                    <columnConstraints>
                        <ColumnConstraints minWidth="120" />
                        <ColumnConstraints minWidth="190" />
                        <ColumnConstraints minWidth="120" />
                        <ColumnConstraints minWidth="190" />
                        <ColumnConstraints minWidth="120" />
                        <ColumnConstraints minWidth="190" />
                    </columnConstraints>

                    <children>
                        <!-- Row 0 -->
                        <Label text="Loại hàng hóa:" styleClass="label" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                        <ComboBox fx:id="cbType" prefWidth="190" styleClass="combo-box" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                        <Label text="Mã định danh (ID):" styleClass="label" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
                        <TextField fx:id="txtId" promptText="VD: SP001" GridPane.columnIndex="3" GridPane.rowIndex="0"/>

                        <Label text="Tên sản phẩm:" styleClass="label" GridPane.columnIndex="4" GridPane.rowIndex="0"/>
                        <TextField fx:id="txtName" promptText="Tên sản phẩm" GridPane.columnIndex="5" GridPane.rowIndex="0"/>

                        <!-- Row 1 -->
                        <Label text="Giá khởi điểm ($):" styleClass="label" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                        <TextField fx:id="txtPrice" promptText="0.0" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                        <Label text="Bước giá tối thiểu ($):" styleClass="label" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
                        <TextField fx:id="txtMinIncrement" promptText="VD: 10.0" GridPane.columnIndex="3" GridPane.rowIndex="1"/>

                        <Label fx:id="lblExtraParam" text="Thông số khác:" styleClass="label" GridPane.columnIndex="4" GridPane.rowIndex="1"/>
                        <TextField fx:id="txtExtraParam" promptText="Nhập thêm..." GridPane.columnIndex="5" GridPane.rowIndex="1"/>

                        <!-- Row 2: Thời gian -->
                        <Label text="Thời gian bắt đầu:" styleClass="label" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                        <TextField fx:id="txtStartTime" promptText="VD: 28/05/2026 10:00" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                        <Label text="Thời gian kết thúc:" styleClass="label" GridPane.columnIndex="2" GridPane.rowIndex="2"/>
                        <TextField fx:id="txtEndTime" promptText="VD: 04/06/2026 10:00" GridPane.columnIndex="3" GridPane.rowIndex="2"/>

                        <Label text="Mô tả sản phẩm:" styleClass="label" GridPane.columnIndex="4" GridPane.rowIndex="2"/>
                        <TextField fx:id="txtDescription" promptText="Mô tả ngắn..." GridPane.columnIndex="5" GridPane.rowIndex="2"/>
                    </children>
                </GridPane>
                <HBox alignment="CENTER_RIGHT" spacing="10" style="-fx-padding: 5 0 0 0;">
                    <Button onAction="#handleAddItem" text="➕  THÊM SẢN PHẨM" styleClass="button" style="-fx-background-color: #10b981;"/>
                </HBox>
            </VBox>

            <!-- Bảng danh sách sản phẩm -->
            <VBox VBox.vgrow="ALWAYS" styleClass="card" style="-fx-padding: 10;">
                <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 0 0 10 5;">
                    <Label text="📦  Sản phẩm của tôi" styleClass="subtitle-label" HBox.hgrow="ALWAYS"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="🔄  Làm mới" onAction="#handleRefresh" styleClass="button-link"/>
                    <Button text="🗑  Xóa sản phẩm chọn" onAction="#handleDeleteItem" styleClass="button-danger"/>
                </HBox>
                <TableView fx:id="table" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="idCol" prefWidth="80" text="Mã ID" />
                        <TableColumn fx:id="typeCol" prefWidth="90" text="Loại" />
                        <TableColumn fx:id="nameCol" prefWidth="200" text="Tên Sản Phẩm" />
                        <TableColumn fx:id="priceCol" prefWidth="120" text="Giá Hiện Tại" />
                        <TableColumn fx:id="minIncCol" prefWidth="110" text="Bước Giá Min" />
                        <TableColumn fx:id="startTimeCol" prefWidth="150" text="Bắt Đầu" />
                        <TableColumn fx:id="endTimeCol" prefWidth="150" text="Kết Thúc" />
                        <TableColumn fx:id="statusCol" prefWidth="100" text="Trạng Thái" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>
            </VBox>
        </VBox>
    </center>
</BorderPane>