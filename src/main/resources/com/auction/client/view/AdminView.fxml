<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="680.0" prefWidth="1050.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.AdminController" styleClass="root">
    <!-- Thanh Header -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" styleClass="header-bar">
            <Label text="TRANG QUẢN TRỊ VIÊN" styleClass="title-label"/>
            <Label text="|  Hệ Thống" styleClass="subtitle-label"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="lblUsername" text="Chào, Admin" styleClass="label" style="-fx-font-weight: bold;"/>
            <Button text="Đăng xuất" onAction="#handleLogout" styleClass="button-danger"/>
        </HBox>
    </top>

    <!-- Phần thân giữa -->
    <center>
        <TabPane tabClosingPolicy="UNAVAILABLE" styleClass="tab-pane" style="-fx-padding: 10;">
            <tabs>
                <!-- Tab 1: Quản lý Người dùng -->
                <Tab text="👥  Quản lý người dùng">
                    <content>
                        <VBox spacing="15" style="-fx-padding: 15;">
                            <!-- Thanh điều khiển người dùng -->
                            <HBox spacing="15" alignment="CENTER_LEFT" styleClass="card" style="-fx-padding: 12 20;">
                                <Label text="Thao tác nhanh:" styleClass="subtitle-label" style="-fx-font-weight: bold; -fx-text-fill: #334155;"/>
                                <Button text="🚫  Ban tài khoản" onAction="#handleBanUser" styleClass="button-danger"/>
                                <Button text="✅  Mở khóa tài khoản" onAction="#handleUnbanUser" style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 7; -fx-padding: 9 20; -fx-cursor: hand;"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Button text="🔄  Làm mới" onAction="#handleRefreshUsers" styleClass="button-link"/>
                            </HBox>
                            
                            <!-- Bảng người dùng -->
                            <VBox VBox.vgrow="ALWAYS" styleClass="card" style="-fx-padding: 10;">
                                <HBox alignment="CENTER_LEFT" style="-fx-padding: 0 0 10 5;">
                                    <Label text="📋  Danh sách thành viên hệ thống" styleClass="subtitle-label"/>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Label fx:id="lblUserCount" text="0 người dùng" styleClass="subtitle-label" style="-fx-font-size: 13px;"/>
                                </HBox>
                                <TableView fx:id="userTable" VBox.vgrow="ALWAYS">
                                    <columns>
                                        <TableColumn fx:id="userUsernameCol" text="Tên đăng nhập" prefWidth="220"/>
                                        <TableColumn fx:id="userRoleCol" text="Vai trò" prefWidth="180"/>
                                        <TableColumn fx:id="userBalanceCol" text="Số dư khả dụng ($)" prefWidth="220"/>
                                        <TableColumn fx:id="userFrozenCol" text="Số dư đóng băng ($)" prefWidth="220"/>
                                        <TableColumn fx:id="userStatusCol" text="Trạng thái" prefWidth="170"/>
                                    </columns>
                                    <placeholder>
                                        <Label text="Không có người dùng nào. Bấm 'Làm mới' để tải lại." styleClass="subtitle-label"/>
                                    </placeholder>
                                </TableView>
                            </VBox>
                        </VBox>
                    </content>
                </Tab>

                <!-- Tab 2: Quản lý Sản phẩm -->
                <Tab text="📦  Quản lý sản phẩm">
                    <content>
                        <VBox spacing="15" style="-fx-padding: 15;">
                            <!-- Thanh tìm kiếm + lọc -->
                            <HBox spacing="10" alignment="CENTER_LEFT" styleClass="card" style="-fx-padding: 12 20;">
                                <Label text="🔍" style="-fx-font-size: 18px;"/>
                                <TextField fx:id="txtSearch" promptText="Tìm kiếm theo tên, mô tả..." HBox.hgrow="ALWAYS" prefWidth="350"/>
                                <Button text="Tìm kiếm" onAction="#handleSearchItem" styleClass="button"/>
                                <Separator orientation="VERTICAL"/>
                                <Button text="🔄  Làm mới" onAction="#handleRefreshAll" styleClass="button-link"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Button text="👁  Xem chi tiết &amp; Theo dõi" onAction="#handleViewDetails" styleClass="button"/>
                            </HBox>

                            <!-- Bảng danh sách sản phẩm -->
                            <VBox VBox.vgrow="ALWAYS" styleClass="card" style="-fx-padding: 10;">
                                <HBox alignment="CENTER_LEFT" style="-fx-padding: 0 0 10 5;">
                                    <Label text="📋  Theo dõi danh sách sản phẩm đấu giá" styleClass="subtitle-label"/>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Label fx:id="lblItemCount" text="0 sản phẩm" styleClass="subtitle-label" style="-fx-font-size: 13px;"/>
                                </HBox>
                                <TableView fx:id="itemTable" VBox.vgrow="ALWAYS">
                                    <columns>
                                        <TableColumn fx:id="itemIdCol" text="ID" prefWidth="60"/>
                                        <TableColumn fx:id="itemNameCol" text="Tên sản phẩm" prefWidth="230"/>
                                        <TableColumn fx:id="itemTypeCol" text="Loại" prefWidth="100"/>
                                        <TableColumn fx:id="itemSellerCol" text="Người bán" prefWidth="110"/>
                                        <TableColumn fx:id="itemPriceCol" text="Giá hiện tại ($)" prefWidth="130"/>
                                        <TableColumn fx:id="itemMinIncCol" text="Bước giá tối thiểu" prefWidth="140"/>
                                        <TableColumn fx:id="itemStartTimeCol" text="Bắt đầu lúc" prefWidth="140"/>
                                        <TableColumn fx:id="itemEndTimeCol" text="Kết thúc lúc" prefWidth="140"/>
                                        <TableColumn fx:id="itemStatusCol" text="Trạng thái" prefWidth="110"/>
                                    </columns>
                                    <placeholder>
                                        <Label text="Không có sản phẩm nào. Bấm 'Làm mới' để tải lại." styleClass="subtitle-label"/>
                                    </placeholder>
                                </TableView>
                            </VBox>
                        </VBox>
                    </content>
                </Tab>
            </tabs>
        </TabPane>
    </center>
</BorderPane>