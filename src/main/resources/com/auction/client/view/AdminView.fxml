<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="500.0" prefWidth="700.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.AdminController">
    <!-- Thanh Header -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-background-color: #d32f2f; -fx-padding: 15;">
            <Label text="TRANG QUẢN TRỊ VIÊN (ADMIN)" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Đăng xuất" onAction="#handleLogout" style="-fx-background-color: white; -fx-text-fill: #d32f2f; -fx-font-weight: bold;"/>
        </HBox>
    </top>

    <!-- Phần thân giữa -->
    <center>
        <TabPane tabClosingPolicy="UNAVAILABLE">
            <!-- Tab Quản lý Người dùng -->
            <Tab text="Quản lý Người dùng">
                <VBox spacing="10" style="-fx-padding: 10;">
                    <TableView fx:id="userTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="usernameCol" text="Tài khoản" prefWidth="200"/>
                            <TableColumn fx:id="roleCol" text="Vai trò" prefWidth="150"/>
                            <TableColumn fx:id="statusCol" text="Trạng thái" prefWidth="150"/>
                        </columns>
                    </TableView>
                    <HBox alignment="CENTER" spacing="10">
                        <Button text="Khóa / Mở khóa tài khoản" onAction="#handleToggleBanUser" style="-fx-background-color: #f57c00; -fx-text-fill: white;"/>
                    </HBox>
                </VBox>
            </Tab>

            <!-- Tab Quản lý Đấu giá -->
            <Tab text="Quản lý Đấu giá (Sản phẩm)">
                <VBox spacing="10" style="-fx-padding: 10;">
                    <TableView fx:id="itemTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="itemIdCol" text="ID" prefWidth="50"/>
                            <TableColumn fx:id="itemNameCol" text="Tên SP" prefWidth="150"/>
                            <TableColumn fx:id="itemSellerCol" text="Người bán" prefWidth="100"/>
                            <TableColumn fx:id="itemPriceCol" text="Giá hiện tại" prefWidth="100"/>
                            <TableColumn fx:id="itemStatusCol" text="Trạng thái Đấu giá" prefWidth="120"/>
                            <TableColumn fx:id="itemBanCol" text="Trạng thái Vi phạm" prefWidth="120"/>
                        </columns>
                    </TableView>
                    <HBox alignment="CENTER" spacing="10">
                        <Button text="Xóa sản phẩm (Vi phạm)" onAction="#handleDeleteViolationItem" style="-fx-background-color: #d32f2f; -fx-text-fill: white;"/>
                    </HBox>
                </VBox>
            </Tab>
        </TabPane>
    </center>
</BorderPane>