<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.LoginController" styleClass="root">
    <VBox alignment="CENTER" spacing="20" maxWidth="350" maxHeight="320">
        <!-- Khu vực Tiêu đề -->
        <VBox alignment="CENTER" spacing="5">
            <Label text="HỆ THỐNG ĐẤU GIÁ" styleClass="title-label" />
            <Label text="Đăng nhập để tiếp tục" styleClass="subtitle-label" />
        </VBox>

        <!-- Form đăng nhập trong thẻ Card -->
        <VBox styleClass="card" spacing="15">
            <VBox spacing="5">
                <Label text="Tên đăng nhập" styleClass="label" />
                <TextField fx:id="txtUsername" promptText="Nhập tài khoản" />
            </VBox>
            
            <VBox spacing="5">
                <Label text="Mật khẩu" styleClass="label" />
                <PasswordField fx:id="txtPassword" promptText="Nhập mật khẩu" />
            </VBox>
            
            <Region minHeight="10" />
            
            <Button text="Đăng nhập" onAction="#handleLogin" maxWidth="Infinity" styleClass="button" />
            
            <HBox alignment="CENTER">
                <Button text="Chưa có tài khoản? Đăng ký ngay" onAction="#handleGoToRegister" styleClass="button-link" />
            </HBox>
        </VBox>
    </VBox>
</StackPane>