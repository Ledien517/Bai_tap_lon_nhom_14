<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="680.0" prefWidth="1050.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.BidderController" styleClass="root">
    <!-- Thanh Header -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" styleClass="header-bar">
            <Label text="SÀN ĐẤU GIÁ" styleClass="title-label"/>
            <Label text="|  Người Mua" styleClass="subtitle-label"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="lblUsername" text="Chào, Người dùng" styleClass="label" style="-fx-font-weight: bold;"/>
            <Label text="•" styleClass="subtitle-label"/>
            <Label text="Số dư:" styleClass="label"/>
            <Label fx:id="lblBalance" text="0.00 $" style="-fx-text-fill: #10b981; -fx-font-weight: bold; -fx-font-size: 15px;"/>
            <Label text="Đóng băng:" styleClass="label"/>
            <Label fx:id="lblFrozenBalance" text="0.00 $" style="-fx-text-fill: #f59e0b; -fx-font-weight: bold; -fx-font-size: 15px;"/>
            <Button text="Nạp tiền" onAction="#handleTopUp" styleClass="button-link"/>
            <Button text="Rút tiền" onAction="#handleWithdraw" styleClass="button-link"/>
            <Button text="Đăng xuất" onAction="#handleLogout" styleClass="button-danger"/>
        </HBox>
    </top>

    <!-- Phần thân giữa -->
    <center>
        <VBox spacing="15" style="-fx-padding: 20;">
            <!-- Toolbar tìm kiếm + lọc -->
            <HBox spacing="10" alignment="CENTER_LEFT" styleClass="card" style="-fx-padding: 15 20;">
                <Label text="🔍" style="-fx-font-size: 18px;"/>
                <TextField fx:id="txtSearch" promptText="Tìm kiếm theo tên, mô tả..." HBox.hgrow="ALWAYS" prefWidth="350"/>
                <Button text="Tìm kiếm" onAction="#handleSearchItem" styleClass="button"/>
                <Separator orientation="VERTICAL"/>
                <Button text="Phiên của tôi" onAction="#handleMyAuctions" styleClass="button-link"/>
                <Button text="🔄  Làm mới" onAction="#handleRefreshAll" styleClass="button-link"/>
                <Button text="Đặt giá ngay" onAction="#handlePlaceBid" styleClass="button"/>
            </HBox>

            <!-- Bảng danh sách sản phẩm -->
            <VBox VBox.vgrow="ALWAYS" styleClass="card" style="-fx-padding: 10;">
                <HBox alignment="CENTER_LEFT" style="-fx-padding: 0 0 10 5;">
                    <Label text="📋  Danh sách sản phẩm đang đấu giá" styleClass="subtitle-label"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="lblItemCount" text="0 sản phẩm" styleClass="subtitle-label" style="-fx-font-size: 13px;"/>
                </HBox>
                <TableView fx:id="table" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="idCol" text="ID" prefWidth="60"/>
                        <TableColumn fx:id="nameCol" text="Tên sản phẩm" prefWidth="230"/>
                        <TableColumn fx:id="typeCol" text="Loại" prefWidth="100"/>
                        <TableColumn fx:id="sellerCol" text="Người bán" prefWidth="110"/>
                        <TableColumn fx:id="priceCol" text="Giá hiện tại ($)" prefWidth="130"/>
                        <TableColumn fx:id="minIncCol" text="Bước giá tối thiểu" prefWidth="140"/>
                        <TableColumn fx:id="startTimeCol" text="Bắt đầu lúc" prefWidth="140"/>
                        <TableColumn fx:id="endTimeCol" text="Kết thúc lúc" prefWidth="140"/>
                        <TableColumn fx:id="statusCol" text="Trạng thái" prefWidth="110"/>
                    </columns>
                    <placeholder>
                        <Label text="Không có sản phẩm nào. Bấm 'Làm mới' để tải lại." styleClass="subtitle-label"/>
                    </placeholder>
                </TableView>
            </VBox>
        </VBox>
    </center>
</BorderPane>