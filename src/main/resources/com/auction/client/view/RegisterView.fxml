<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.collections.FXCollections?>
<?import com.auction.common.model.Role?>

<StackPane xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.RegisterController" styleClass="root">
    <VBox alignment="CENTER" spacing="20" maxWidth="350" maxHeight="380">
        <!-- Khu vực Tiêu đề -->
        <VBox alignment="CENTER" spacing="5">
            <Label text="ĐĂNG KÝ TÀI KHOẢN" styleClass="title-label" />
            <Label text="Tham gia hệ thống đấu giá ngay" styleClass="subtitle-label" />
        </VBox>

        <!-- Form đăng ký trong thẻ Card -->
        <VBox styleClass="card" spacing="15">
            <VBox spacing="5">
                <Label text="Tên đăng nhập" styleClass="label" />
                <TextField fx:id="txtUsername" promptText="Nhập tên tài khoản" />
            </VBox>
            
            <VBox spacing="5">
                <Label text="Mật khẩu" styleClass="label" />
                <PasswordField fx:id="txtPassword" promptText="Nhập mật khẩu" />
            </VBox>

            <VBox spacing="5">
                <Label text="Vai trò" styleClass="label" />
                <ComboBox fx:id="cbRole" maxWidth="Infinity" styleClass="combo-box" />
            </VBox>
            
            <Region minHeight="10" />
            
            <Button text="Đăng ký" onAction="#handleRegister" maxWidth="Infinity" styleClass="button" />
            
            <HBox alignment="CENTER">
                <Button text="Đã có tài khoản? Đăng nhập" onAction="#handleGoToLogin" styleClass="button-link" />
            </HBox>
        </VBox>
    </VBox>
</StackPane>