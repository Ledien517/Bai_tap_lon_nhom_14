<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.LineChart?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="500.0" prefWidth="700.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.AuctionDetailController">
    <children>
        <VBox layoutX="20.0" layoutY="20.0" spacing="15.0">
            <Label text="Chi Tiết Đấu Giá" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

            <Label text="Thời gian còn lại:" />
            <Label fx:id="timeLabel" text="00:00:00" style="-fx-font-size: 24px; -fx-text-fill: red; -fx-font-weight: bold;"/>

            <Label text="Giá hiện tại:" />
            <Label fx:id="priceLabel" text="0.00 VND" style="-fx-font-size: 18px; -fx-text-fill: green; -fx-font-weight: bold;"/>

            <Label text="Người dẫn đầu:" />
            <Label fx:id="bidderLabel" text="-" />

            <TextField fx:id="bidInput" promptText="Nhập mức giá..." prefWidth="200.0" />
            <Button fx:id="btnBid" mnemonicParsing="false" onAction="#handlePlaceBid" text="Đặt Giá" />
        </VBox>

        <LineChart fx:id="bidHistoryChart" layoutX="250.0" layoutY="50.0" prefHeight="400.0" prefWidth="430.0" title="Biểu đồ giá Realtime">
            <xAxis>
                <CategoryAxis label="Thời gian" side="BOTTOM" />
            </xAxis>
            <yAxis>
                <NumberAxis label="Giá (VND)" side="LEFT" />
            </yAxis>
        </LineChart>
    </children>
</AnchorPane>