<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.collections.FXCollections?>
<?import com.auction.common.model.Role?>

<GridPane alignment="CENTER" hgap="10" vgap="10" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.RegisterController">
    <padding><Insets bottom="20" left="20" right="20" top="20"/></padding>

    <Label text="ĐĂNG KÝ TÀI KHOẢN" style="-fx-font-size: 18px; -fx-font-weight: bold;" GridPane.columnIndex="0" GridPane.rowIndex="0" GridPane.columnSpan="2" GridPane.halignment="CENTER"/>

    <Label text="Tên đăng nhập:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
    <TextField fx:id="txtUsername" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

    <Label text="Mật khẩu:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
    <PasswordField fx:id="txtPassword" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

    <Label text="Vai trò:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
    <ComboBox fx:id="cbRole" GridPane.columnIndex="1" GridPane.rowIndex="3"/>

    <HBox alignment="CENTER_RIGHT" spacing="10" GridPane.columnIndex="1" GridPane.rowIndex="4">
        <Button text="Đăng ký" onAction="#handleRegister"/>
    </HBox>

    <Button text="Đã có tài khoản? Đăng nhập" onAction="#handleGoToLogin" GridPane.columnIndex="0" GridPane.rowIndex="5" GridPane.columnSpan="2" GridPane.halignment="CENTER"/>
</GridPane>