<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="550.0" prefWidth="780.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.auction.client.controller.BidderController">

    <!-- Thanh Header -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20"
              style="-fx-background-color: #1976d2; -fx-padding: 15;">
            <Label text="SÀN ĐẤU GIÁ TRỰC TUYẾN"
                   style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Đăng xuất" onAction="#handleLogout"
                    style="-fx-background-color: white; -fx-text-fill: #1976d2; -fx-font-weight: bold;"/>
        </HBox>
    </top>

    <!-- Phần thân -->
    <center>
        <VBox alignment="CENTER" spacing="10" style="-fx-padding: 20;">

            <!-- Thông tin người dùng + số dư -->
            <HBox spacing="15" alignment="CENTER_LEFT">
                <Label fx:id="lblUsername" text="Chào, Người dùng"
                       style="-fx-font-weight: bold; -fx-font-size: 14px;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="Số dư khả dụng:"
                       style="-fx-font-weight: bold;"/>
                <Label fx:id="lblBalance" text="0.00 $"
                       style="-fx-text-fill: #2e7d32; -fx-font-weight: bold; -fx-font-size: 14px;"/>
            </HBox>

            <!-- Bảng danh sách sản phẩm -->
            <TableView fx:id="table" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="idCol"     text="ID"          prefWidth="60"/>
                    <TableColumn fx:id="nameCol"   text="Tên sản phẩm" prefWidth="200"/>
                    <TableColumn fx:id="typeCol"   text="Loại"        prefWidth="100"/>
                    <TableColumn fx:id="priceCol"  text="Giá hiện tại" prefWidth="120"/>
                    <TableColumn fx:id="statusCol" text="Trạng thái"  prefWidth="100"/>
                </columns>
                <placeholder>
                    <Label text="Chưa có sản phẩm nào. Seller cần đăng sản phẩm trước."/>
                </placeholder>
            </TableView>

            <!-- Các nút chức năng -->
            <HBox alignment="CENTER" spacing="15" style="-fx-padding: 8;">
                <Button text="🔍 Tìm kiếm" onAction="#handleSearchItem"/>
                <Button text="💰 Đặt giá nhanh" onAction="#handlePlaceBid"
                        style="-fx-background-color: #1976d2; -fx-text-fill: white; -fx-font-weight: bold;"/>
                <Button text="➕ Nạp tiền" onAction="#handleTopUp"
                        style="-fx-background-color: #388e3c; -fx-text-fill: white; -fx-font-weight: bold;"/>
                <Button text="➖ Rút tiền" onAction="#handleWithdraw"
                        style="-fx-background-color: #f57c00; -fx-text-fill: white; -fx-font-weight: bold;"/>
            </HBox>

        </VBox>
    </center>
</BorderPane>
